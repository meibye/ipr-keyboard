# Normalize all text files to LF
* text=auto

# Explicitly set shell scripts and Python files to LF
*.sh       text eol=lf
*.py       text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.conf     text eol=lf
*.env      text eol=lf
*.txt      text eol=lf
*.service  text eol=lf
*.timer    text eol=lf
*.ps1      text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.svg      text eol=lf
*.lock     text eol=lf
*.example  text eol=lf

# Dotfiles without extensions
.gitattributes text eol=lf
.gitignore     text eol=lf
.python-version text eol=lf

# Windows-specific files (if any)
*.bat text eol=crlf
*.cmd text eol=crlf
