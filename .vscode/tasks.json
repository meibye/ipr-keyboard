{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Update VERSION stamp",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\update-version.ps1",
                "-FilePath",
                "${file}",
                "-SearchLinesFromTop",
                "120"
            ],
            "presentation": {
                "reveal": "never",
                "panel": "shared",
                "clear": false
            },
            "problemMatcher": [],
            "runOptions": {
                "reevaluateOnRerun": true
            }
        },
        {
            "label": "Launch Local Claude (with GPU Check)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/scripts/launch_claude.ps1"
            ],
            "options": {
                "env": {
                    "ANTHROPIC_BASE_URL": "http://localhost:11434/v1",
                    "ANTHROPIC_AUTH_TOKEN": "ollama",
                    "ANTHROPIC_API_KEY": "ollama"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            }
        }
    ]
}